[0.007308, "o", "\u001b[2J\u001b[H"]
[0.007919, "o", "\u001b[1;36m# sage — pure bash AI agent orchestrator\u001b[0m\r\n"]
[1.008695, "o", "\u001b[1;36m# Zero frameworks, zero dependencies beyond bash/jq/tmux\u001b[0m\r\n"]
[3.011084, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage --version\r\n"]
[3.637985, "o", "sage 1.3.0\r\n"]
[4.839387, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage init\r\n"]
[5.486774, "o", "\u001b[0;32m✓\u001b[0m sage initialized at /tmp/tmp.6aAW0oHysH/sage-demo\r\n"]
[6.688229, "o", "\u001b[1;36m# sage demo scaffolds a working 3-agent fan-out example\u001b[0m\r\n"]
[7.689398, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage demo\r\n"]
[8.339301, "o", "demo: created demo-reviewer\r\n"]
[8.358765, "o", "demo: created demo-tester\r\n"]
[8.377637, "o", "demo: created demo-security\r\n"]
[8.37888, "o", "demo: wrote /tmp/tmp.6aAW0oHysH/sage-demo/plans/demo-fan-out.yaml\r\n"]
[8.379991, "o", "\r\n  ✨ Demo scaffolded. Try:\r\n    sage ls                        # see your 3 demo agents\r\n    sage plan --run /tmp/tmp.6aAW0oHysH/sage-demo/plans/demo-fan-out.yaml     # run the fan-out pattern\r\n    sage send demo-reviewer \"hi\"   # talk to one agent\r\n    sage demo --clean              # tear it all down\r\n"]
[9.581696, "o", "\u001b[1;36m# Three agents created, ready to review code in parallel:\u001b[0m\r\n"]
[10.582801, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage ls\r\n"]
[11.240129, "o", "demo-reviewer\r\ndemo-security\r\n"]
[11.240192, "o", "demo-tester\r\n"]
[12.441728, "o", "\u001b[1;36m# And a plan YAML wired up for fan-out execution:\u001b[0m\r\n"]
[13.442896, "o", "\u001b[1;32m$\u001b[0m cat /tmp/tmp.6aAW0oHysH/sage-demo/plans/demo-fan-out.yaml\r\n"]
[14.044985, "o", "# sage demo plan — fan-out pattern\r\n# Run: sage plan --run <this-file>\r\npattern: fan-out\r\ntask: \"Analyze the input and report findings\"\r\ninputs: [demo-reviewer, demo-tester, demo-security]\r\n"]
[15.2463, "o", "\u001b[1;36m# sage acp ls — discover agents from the ACP Registry (live)\u001b[0m\r\n"]
[16.42643, "o", "  amp-acp                  Amp                  ACP wrapper for Amp - the frontier coding agent\r\n  auggie                   Auggie CLI           Augment Code's powerful software agent, backed by industry-leading context engine\r\n  autohand                 Autohand Code        Autohand Code - AI coding agent powered by Autohand AI\r\n  claude-acp               Claude Agent         ACP wrapper for Anthropic's Claude\r\n  cline                    Cline                Autonomous coding agent CLI - capable of creating/editing files, running commands, using the browser, and more\r\n  codebuddy-code           Codebuddy Code       Tencent Cloud's official intelligent coding tool\r\n  codex-acp                Codex CLI            ACP adapter for OpenAI's coding assistant\r\n  corust-agent             Corust Agent         Co-building with a seasoned Rust partner.\r\n  crow-cli                 crow-cli             Minimal ACP Native Coding Agent\r\n  cursor                   Cursor               Cursor's coding agent\r\n  deepagents               DeepAgents           Batteries-included AI coding and general purpose agent powered by LangChain.\r\n  factory-droid            Factory Droid        Factory Droid - AI coding agent powered by Factory AI\r\n"]
[18.428295, "o", "\u001b[1;36m# That's it. 53 commands, 8 runtimes, 928 tests. Pure bash.\u001b[0m\r\n"]
