{"version": 2, "width": 100, "height": 28, "timestamp": 1776985435, "idle_time_limit": 3.0, "env": {"SHELL": "/bin/zsh", "TERM": null}}
[0.056934, "o", "\u001b[2J\u001b[H\u001b[1;36m# Kill-switch drill: your primary AI vendor goes down. Workflow survives.\u001b[0m\r\n"]
[2.258205, "o", "\u001b[1;36m# Why this matters: every other orchestrator is single-vendor-locked.\u001b[0m\r\n"]
[4.459743, "o", "\u001b[1;36m# Step 1: Create 3 agents across 3 different vendors.\u001b[0m\r\n"]
[6.660947, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage create reviewer-primary --runtime claude-code\r\n"]
[7.506319, "o", "\u001b[0;32m✓\u001b[0m agent 'reviewer-primary' created (runtime=claude-code)\r\n"]
[7.506456, "o", "\u001b[0;36m▸\u001b[0m edit /tmp/tmp.Dw9Fd5L80g/sage-killswitch/agents/reviewer-primary/instructions.md to customize behavior\r\n"]
[10.007915, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage create reviewer-gemini --runtime gemini-cli\r\n"]
[10.853104, "o", "\u001b[0;32m✓\u001b[0m agent 'reviewer-gemini' created (runtime=gemini-cli)\r\n"]
[10.853231, "o", "\u001b[0;36m▸\u001b[0m edit /tmp/tmp.Dw9Fd5L80g/sage-killswitch/agents/reviewer-gemini/instructions.md to customize behavior\r\n"]
[13.35468, "o", "\u001b[1;32m$\u001b[0m /home/dyouwang/SageCLI/sage create reviewer-local --runtime ollama --model llama3.2:3b\r\n"]
[14.200652, "o", "\u001b[0;32m✓\u001b[0m agent 'reviewer-local' created (runtime=ollama)\r\n"]
[14.200776, "o", "\u001b[0;36m▸\u001b[0m edit /tmp/tmp.Dw9Fd5L80g/sage-killswitch/agents/reviewer-local/instructions.md to customize behavior\r\n"]
[16.70226, "o", "\u001b[1;36m# Step 2: Simulate cloud outage — mask Claude + Gemini from PATH.\u001b[0m\r\n"]
[18.909844, "o", "\u001b[1;32m$\u001b[0m # claude & gemini binaries no longer on PATH\r\n"]
[20.910916, "o", "\u001b[1;36m# Step 3: Send task with fallback chain. Primary = Claude (unreachable).\u001b[0m\r\n"]
[23.160158, "o", "\u001b[0;33m⚠\u001b[0m primary 'reviewer-primary' runtime unreachable → failing over to 'reviewer-local'\r\n"]
[23.679487, "o", "\u001b[0;32m✓\u001b[0m started reviewer-local (runtime=ollama)\r\n"]
[23.712336, "o", "\u001b[0;32m✓\u001b[0m task \u001b[1mt-1776985459-14116\u001b[0m → reviewer-local\r\n\u001b[0;36m▸\u001b[0m track: sage tasks reviewer-local | sage result t-1776985459-14116\r\n"]
[26.714069, "o", "\u001b[1;36m# Notice: sage pre-flight health-checked claude, gemini, then routed to ollama.\u001b[0m\r\n"]
[28.915138, "o", "\u001b[1;36m# Same API, different vendor, zero user intervention.\u001b[0m\r\n"]
[31.154386, "o", "\u001b[1;36m# Step 4: Retrieve the result — done on the local fallback.\u001b[0m\r\n"]
[33.355475, "o", "\u001b[1;32m$\u001b[0m sage result t-1776985459-14116 --json | jq -r .output\r\n"]
[34.18978, "o", "(task done — see sage logs)\r\n"]
[38.193784, "o", "\u001b[1;36m# That's the vendor-neutrality moat. Only sage does this today.\u001b[0m\r\n"]
