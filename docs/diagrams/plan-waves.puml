@startuml plan-waves
!theme plain
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam sequenceArrowThickness 1.5

title Plan Orchestrator — Dependency Waves with Parallel Execution

actor User
participant "sage plan" as sage
participant "planner agent" as planner
box "Wave 1" #F0F8FF
  participant "Task 1\nspec" as t1
end box
box "Wave 2 (parallel)" #F0FFF0
  participant "Task 2\nauth" as t2
  participant "Task 3\ncrud" as t3
end box
box "Wave 3 (parallel)" #FFF8F0
  participant "Task 4\ntests" as t4
  participant "Task 5\ndocs" as t5
end box

User -> sage : plan "Build REST API"
sage -> planner : decompose goal
planner --> sage : 5 tasks + deps
sage -> User : show waves [a]pprove
User --> sage : approve

sage -> t1 : run #1
t1 --> sage : ✓ schema.yaml

sage -> t2 : run #2 (ctx=#1)
sage -> t3 : run #3 (ctx=#1)
t2 --> sage : ✓ auth.py
t3 --> sage : ✓ crud.py

sage -> t4 : run #4 (ctx=#2,#3)
sage -> t5 : run #5 (ctx=#2,#3)
t4 --> sage : ✓ tests pass
t5 --> sage : ✓ API.md
sage --> User : plan complete

@enduml
