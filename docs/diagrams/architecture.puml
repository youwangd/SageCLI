@startuml architecture
!theme plain
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam backgroundColor transparent
skinparam ArrowColor #444
skinparam sequenceArrowThickness 1.5

title SageCLI — Message Lifecycle

actor  User
participant "sage CLI\n(bash script)" as cli
database "inbox/\n(JSON files)" as inbox
participant "runner.sh\n(tmux, polls 300ms)" as runner
participant "runtime shim\nruntimes/<name>.sh" as shim
participant    "LLM backend\nclaude-code · ollama ·\ngemini · codex · ..." as llm
database "results/\nworkspace/" as out

User   -> cli    : (1) sage send <agent> "task"
cli    -> inbox  : (2) write msg.json
inbox  -> runner : (3) pickup (next poll)
runner -> shim   : (4) source + runtime_inject()
shim   -> llm    : (5) prompt
llm    --> shim  : (6) stream tokens
shim   -> out    : (7) write task.json + files
out    --> User  : (8) sage ls / tail

@enduml
